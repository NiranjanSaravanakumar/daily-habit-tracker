# Server
PORT=3000

# JWT Secret – use a strong random string in production
JWT_SECRET=your_jwt_secret_here

# Email credentials (Gmail example – enable "App Passwords" for Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Test Mode – set to "true" to skip OTP verification on signup
TEST_MODE=false

# Environment – set to "development" or "test" for seeding test users
NODE_ENV=development
